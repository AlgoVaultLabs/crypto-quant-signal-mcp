# OPS-TRADE-CALL-CALIBRATION-AUDIT-W1 R3 — logrotate config for the
# additive confidence-bucket observability log written by
# src/lib/confidence-bucket-logger.ts (gated on ENABLE_CONFIDENCE_BUCKET_LOGGING=1).
#
# Installed to /etc/logrotate.d/algovault-seed-confidence by deploy.yml.
# Log path is created by the docker-logs → host-syslog forwarder OR by a
# tail-and-fan-out cron consuming docker logs for the `[seed-confidence-bucket]`
# prefix. Path-pattern is intentionally a glob so date-rotated files match.
#
# TODO: ENABLE_CONFIDENCE_BUCKET_LOGGING revisit by 2026-06-11
# (14-day rule per CLAUDE.md "Defensive thresholds get tracked follow-ups").

/var/log/algovault-seed-confidence/*.log {
    weekly
    rotate 4
    compress
    delaycompress
    missingok
    notifempty
    copytruncate
    dateext
    dateformat -%Y-%m-%d
    create 0640 root root
}
