# Transport mode (http = remote server, stdio = local)
TRANSPORT=http
PORT=3000

# Stripe subscription billing
STRIPE_SECRET_KEY=           # sk_test_... or sk_live_...
STRIPE_WEBHOOK_SECRET=       # whsec_...
STRIPE_PRO_PRICE_ID=         # price_...
STRIPE_ENTERPRISE_PRICE_ID=  # price_...
CQS_API_KEY=  # For local testing of pro tier

# x402 payments (USDC on Base)
# Set your recipient wallet address to enable x402 micropayments.
# Without this, the server still works on free/API-key tiers.
X402_WALLET_ADDRESS=0xYourBaseWalletAddress
X402_NETWORK=base-mainnet  # or base-sepolia for testing
X402_FACILITATOR_URL=http://facilitator:4022  # self-hosted facilitator (Docker internal)

# Self-hosted facilitator (gas wallet for on-chain settlement)
# Generate a fresh key — this wallet only needs ~0.01 ETH on Base for gas.
FACILITATOR_PRIVATE_KEY=0xYourGasWalletPrivateKey

# Database (if set, uses PostgreSQL; if not, uses local SQLite)
DATABASE_URL=postgresql://algovault:password@localhost:5432/signal_performance

# Admin analytics endpoint (optional — enables GET /analytics)
ADMIN_API_KEY=

# Monitoring (optional)
UPTIMEROBOT_API_KEY=ur_xxxxxxxxxxxx
